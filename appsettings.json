{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",

  "MasterDb": {
    "ConnectionString": "SET-IN-appsettings.Development.json-OR-USER-SECRETS"
  },

  "Jwt": {
    "Issuer": "SaaS.Api",
    "Audience": "SaaS.Client",
    "SigningKey": "SET-A-64+-CHAR-SECRET-IN-USER-SECRETS-OR-ENVIRONMENT",
    "AccessTokenMinutes": 60,
    "RefreshTokenDays": 7
  },

  "Smtp": {
    "Host": "smtp.example.com",
    "Port": 587,
    "EnableSsl": true,
    "UserName": "SET-IN-SECRETS",
    "Password": "SET-IN-SECRETS",
    "FromAddress": "no-reply@example.com",
    "FromDisplayName": "Your SaaS App",
    "ResetPasswordBaseUrl": "https://yourdomain.com/reset-password"
  }
}
